# Vite exposes env vars to the browser only if they start with VITE_
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_PAYSTACK_PUBLIC_KEY="paystack_public_key_here"
PAYSTACK_SECRET_KEY="paystack_secret_key_here"

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile)
VITE_TURNSTILE_SITE_KEY="your_turnstile_site_key_here"
TURNSTILE_SECRET_KEY="your_turnstile_secret_key_here"

