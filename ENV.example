# Vite exposes env vars to the browser only if they start with VITE_
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_PAYSTACK_PUBLIC_KEY="paystack_public_key_here"
PAYSTACK_SECRET_KEY="paystack_secret_key_here"

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile)
VITE_TURNSTILE_SITE_KEY="your_turnstile_site_key_here"
TURNSTILE_SECRET_KEY="your_turnstile_secret_key_here"

# Contact form email (Resend — https://resend.com, verify mywakapadi.com domain)
RESEND_API_KEY="re_your_resend_api_key"
CONTACT_FROM_EMAIL="Wakapadi <contact@mywakapadi.com>"

# Optional override if your deployment domain does not expose process.env.URL
PAYSTACK_CALLBACK_URL="https://your-live-domain.com/payment-success"
PAYSTACK_WEBHOOK_URL="https://your-live-domain.com/.netlify/functions/paystack-webhook"

