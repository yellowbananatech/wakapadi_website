# =============================================================================
# Wakapadi — Netlify environment variables
# =============================================================================
# Set these in: Netlify → Site settings → Environment variables
#
# BUILD-TIME (Vite — must start with VITE_, scoped to "Production" builds):
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_TURNSTILE_SITE_KEY,
#   VITE_PAYMENT_PROVIDER, VITE_PAYSTACK_PUBLIC_KEY (only if using Paystack)
#
# RUNTIME (Netlify Functions — no VITE_ prefix):
#   All keys below without VITE_ are read by serverless functions only.
# =============================================================================

# --- Frontend (build time) ---

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Payment provider: flutterwave (default) or paystack
VITE_PAYMENT_PROVIDER="flutterwave"

# Cloudflare Turnstile (optional — login / payments if enabled in UI)
VITE_TURNSTILE_SITE_KEY="your_turnstile_site_key_here"

# Paystack public key — only needed when VITE_PAYMENT_PROVIDER=paystack
VITE_PAYSTACK_PUBLIC_KEY="pk_live_or_test_key"

# --- Flutterwave (recommended — server-side only except provider flag above) ---

# Secret key from Flutterwave dashboard → Settings → API keys
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST_or_LIVE_..."

# Webhook secret hash from Flutterwave dashboard → Settings → Webhooks
FLUTTERWAVE_WEBHOOK_SECRET_HASH="your_webhook_secret_hash"

# Where Flutterwave redirects the customer after checkout (optional override)
FLUTTERWAVE_CALLBACK_URL="https://mywakapadi.com/payment-success"

# Configure in Flutterwave dashboard → Settings → Webhooks:
#   https://mywakapadi.com/.netlify/functions/flutterwave-webhook

# --- Paystack (legacy — only if VITE_PAYMENT_PROVIDER=paystack) ---

PAYSTACK_SECRET_KEY="sk_live_or_test_key"
PAYSTACK_CALLBACK_URL="https://mywakapadi.com/payment-success"
# Paystack dashboard webhook:
#   https://mywakapadi.com/.netlify/functions/paystack-webhook

# --- Shared payment redirect (optional — overrides provider-specific callback) ---

PAYMENT_CALLBACK_URL="https://mywakapadi.com/payment-success"

# Server-side default provider if VITE_ not available (functions only)
PAYMENT_PROVIDER="flutterwave"

# --- Contact form email ---

# Primary: Resend (https://resend.com — verify mywakapadi.com domain)
RESEND_API_KEY="re_your_resend_api_key"
CONTACT_FROM_EMAIL="Wakapadi Website <contact@mywakapadi.com>"
CONTACT_TO_EMAIL="hello@mywakapadi.com"
CONTACT_CC_EMAILS="wakapadi@icloud.com,therealveev@gmail.com"

# Fallback: Netlify Email extension (if Resend is not configured)
# NETLIFY_EMAILS_PROVIDER="sendgrid"
# NETLIFY_EMAILS_PROVIDER="mailgun"
# NETLIFY_EMAILS_PROVIDER_API_KEY="your_provider_api_key"
# NETLIFY_EMAILS_MAILGUN_DOMAIN="mg.mywakapadi.com"
# NETLIFY_EMAILS_SECRET="your_netlify_emails_secret"

# --- Cloudflare Turnstile (server) ---

TURNSTILE_SECRET_KEY="your_turnstile_secret_key_here"

# --- Optional site URL overrides (Netlify usually sets URL automatically) ---

# SITE_URL="https://mywakapadi.com"
